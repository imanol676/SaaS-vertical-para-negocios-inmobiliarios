generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organizations {
  id             String   @id @default(uuid()) @db.Uuid
  clerk_org_id   String   @unique
  name           String
  plan           String
  plan_status    String   @default("active")
  trial_ends_at  DateTime?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  users      Users[]
  events     Events[]
  properties Properties[]
  leads      Leads[]

  @@map("organizations")
}

model Users {
  id              String   @id @default(uuid()) @db.Uuid
  clerk_user_id   String   @unique
  organization_id String   @db.Uuid
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization   Organizations @relation(fields: [organization_id], references: [id])
  assigned_leads Leads[]

  @@index([organization_id])
  @@map("users")
}

model Events {
  id              String   @id @default(uuid()) @db.Uuid
  organization_id String   @db.Uuid
  type            String
  entity_id       String   @db.Uuid
  payload         Json
  created_at      DateTime @default(now())

  organization Organizations @relation(fields: [organization_id], references: [id])

  @@index([organization_id])
  @@map("events")
}

model Properties {
  id              String   @id @default(uuid()) @db.Uuid
  organization_id String   @db.Uuid
  title           String
  type            String
  price           Decimal
  location        String
  status          String
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization Organizations @relation(fields: [organization_id], references: [id])
  leads        Leads[]

  @@index([organization_id])
  @@map("properties")
}

model Leads {
  id               String   @id @default(uuid()) @db.Uuid
  organization_id  String   @db.Uuid
  property_id      String?  @db.Uuid
  assigned_user_id String?  @db.Uuid

  source        String
  name          String
  email         String?
  phone         String?
  budget        Decimal?
  zone          String?
  timeframe     String?

  raw_payload   Json
  status        String

  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  organization  Organizations @relation(fields: [organization_id], references: [id])
  property      Properties?   @relation(fields: [property_id], references: [id])
  assigned_user Users?        @relation(fields: [assigned_user_id], references: [id])

  lead_scores   LeadScores[]

  @@index([organization_id])
  @@index([assigned_user_id])
  @@map("leads")
}

model LeadScores {
  id            String   @id @default(uuid()) @db.Uuid
  lead_id       String   @db.Uuid
  score         Int
  label         String
  explanation   Json
  model_version String
  created_at    DateTime @default(now())

  lead Leads @relation(fields: [lead_id], references: [id])

  @@index([lead_id])
  @@map("lead_scores")
}